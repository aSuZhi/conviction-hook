# Conviction project environment template
# Copy this file to .env and fill in secrets locally.
# Never commit .env.

# Network RPCs
XLAYER_TESTNET_RPC_URL=https://xlayer-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
XLAYER_MAINNET_RPC_URL=https://xlayer-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Deployer wallet
# Use a dedicated hackathon deployer wallet, not your primary wallet.
DEPLOYER_PRIVATE_KEY=
DEPLOYER_ADDRESS=

# Agentic Wallet demo account
AGENTIC_WALLET_EVM_ADDRESS=

# X Layer explorer / verification
XLAYER_TESTNET_EXPLORER_API_KEY=
XLAYER_MAINNET_EXPLORER_API_KEY=

# Uniswap v4 deployment addresses on X Layer
# Fill these if official or hackathon-provided deployments exist.
XLAYER_TESTNET_V4_POOL_MANAGER=
XLAYER_TESTNET_V4_POSITION_MANAGER=
XLAYER_TESTNET_V4_SWAP_ROUTER=
XLAYER_TESTNET_V4_STATE_VIEW=

XLAYER_MAINNET_V4_POOL_MANAGER=0x360e68faccca8ca495c1b759fd9eee466db9fb32
XLAYER_MAINNET_V4_POSITION_MANAGER=0xcf1eafc6928dc385a342e7c6491d371d2871458b
XLAYER_MAINNET_V4_SWAP_ROUTER=
XLAYER_MAINNET_V4_STATE_VIEW=0x76fd297e2d437cd7f76d50f01afe6160f86e9990

# Optional: if we deploy our own v4 stack for testnet demo, store addresses here.
LOCAL_OR_PROJECT_V4_POOL_MANAGER=
LOCAL_OR_PROJECT_V4_POSITION_MANAGER=
LOCAL_OR_PROJECT_V4_SWAP_ROUTER=
